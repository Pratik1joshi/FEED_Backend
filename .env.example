# Environment Variables
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:pass123@localhost:5432/mydb

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
# Optional comma-separated allowed origins (recommended for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# JWT Secret (Generate a secure random string)
JWT_SECRET=your_super_secure_jwt_secret_key_here_change_in_production

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@feed.org.np
ADMIN_PASSWORD=admin123

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Rate Limiting
# Public read endpoints (GET/HEAD/OPTIONS)
PUBLIC_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_RATE_LIMIT_MAX_REQUESTS=5000

# Mutating endpoints (POST/PUT/PATCH/DELETE)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# Mail Settings (used as fallback when admin settings are empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM_NAME=FEED Website
MAIL_FROM_EMAIL=no-reply@feed.org.np
